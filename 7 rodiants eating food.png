header{
    background-color: rgb(124, 96, 35);
    color: ghostwhite;

}

main{
    background-color: rgb(172, 120, 53);
    color: rgb(255, 255, 255);


}

footer{
    background-color: rgb(255, 255, 255);
    color: rgb(94, 68, 13);

}

    underdog-regular {
    font-family: "Underdog", system-ui;
    font-weight: 400;
    font-style: normal;
  }
  
  header{
    background-color:#f3e2dd;
    color: rgb(13, 14, 29);
    font-family: Arial, sans-serif;
    text-align: left;
    padding: 50px;
   }
    
   main{
   color:rgb(13, 14, 29);
   font-family: Arial, sans-serif;
   text-align: center;
   padding: 50px;
   text-align: left;
   }
    
   footer.transparent-text{
   color:rgb(148, 148, 148);
   font-family: Arial, sans-serif;
   text-align: center;
   padding: 50px;
   text-align: left;
    
   }
    
   nav ul {
   list-style: none;      /* removes bullet points */
   padding: 0;
    margin: 0;
   display: flex;         /* keeps links in a row */
   gap: 20px;             /* spacing between links */
    
   }
    
   nav ul li {
   display: inline;       /* makes each list item sit side-by-side */
   }
    
   nav ul li a {
   text-decoration: none; /* removes underline */
   color: inherit;        /* keeps your current colour */
   font-weight: bold;     /* matches your screenshot */
   }
    
   nav ul {
   display: flex;
   flex-direction: row;
   align-content: space-around;
   justify-items: center;
   gap: 10px;
   margin: 0 auto;
    
   }
    
   nav ul li {
    
   display: inherit;
   padding: 10px 20px;
   border: none;
    
   }
    
   nav ul li:hover{
   font-family: Arial, Helvetica, sans-serif;
   font-size: 18px;
   color:rgb(13, 14, 29,);
   text-decoration: none;
    
   }

   nav ul li:hover{
    border-bottom:1px solid rgb(224, 224, 224);
    transform: translateZ(10px) scale(1.1);
    box-shadow: 0 8px 20px rgb(0, 0, 0);
    background-color:  rgb(255, 255, 255);
     }